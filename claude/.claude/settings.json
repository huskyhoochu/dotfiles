{
  "permissions": {
    "allow": []
  },
  "statusLine": {
    "type": "command",
    "command": "echo \"$(basename \"$(pwd)\") $(git -c core.useBuiltinFSMonitor=false branch --show-current 2>/dev/null | sed 's/^/on /')\""
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "perplexity@perplexity-mcp-server": true,
    "commit-commands@claude-plugins-official": true,
    "linear@claude-plugins-official": false,
    "Notion@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "language": "한국어",
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/cyprien/.claude/hooks/cleanup-orphaned-claude.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
