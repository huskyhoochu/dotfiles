theme = Rose Pine Moon
font-size = 16
background-opacity = 0.8
background-blur = 20
gtk-titlebar = true
macos-titlebar-style = hidden

# 기본 폰트 (영어 및 일반 문자)
font-family = "Monofur Nerd Font Mono"

# 한국어 문자를 위한 폴백 폰트
font-family = "Xiaolai Mono SC"

# Claude Code (Shift+Enter = 줄바꿈 구분)
keybind = alt+backspace=text:\x1b\x7f
